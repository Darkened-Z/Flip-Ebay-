# Supabase — copy this file to .env.local and fill in your project values.
# Find these in your Supabase dashboard: Project Settings → API.

# Project URL (e.g. https://abcdefgh.supabase.co) — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key — safe to expose to the browser (RLS protects your data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — SERVER ONLY. Never expose to the browser. Used for
# trusted server-side jobs (e.g. inventory monitor, order sync, daily hunt cron).
SUPABASE_SERVICE_ROLE_KEY=

# Amazon product / search / deals data (rainforestapi.com)
RAINFOREST_API_KEY=

# eBay sold comps + active competition (serpapi.com). Optional fallback now that
# eBay is scraped via ScraperAPI — only used if SCRAPERAPI_KEY is unset.
SERPAPI_KEY=

# eBay sold comps via a maintained Apify actor (apify.com). Free tier: $5/mo
# credit (~100 runs). PREFERRED eBay source — when set, used before everything
# else. APIFY_ACTOR overrides the default ebay-sold-lite actor if needed.
APIFY_TOKEN=
# APIFY_ACTOR=astronomical_reception~ebay-sold-lite

# Free scraping proxy (scraperapi.com) — alternative eBay source: fetches the
# sold page past anti-bot blocking and we parse it. Free 5,000 + 1,000/month.
SCRAPERAPI_KEY=
